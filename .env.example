# Public Supabase credentials. Safe to expose in the browser bundle - Row Level
# Security is what protects the data. Copy to .env.local for local development,
# and set the same two variables in the Netlify site settings.
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon / publishable key>
